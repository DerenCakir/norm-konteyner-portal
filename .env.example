# Supabase Transaction Pooler (port 6543, IPv4)
# Direct connection (5432) Railway'de IPv6 desteklenmediği için ÇALIŞMAZ.
# Supabase Dashboard > Project Settings > Database > Connection string > "Transaction"
DATABASE_URL=postgresql://postgres.PROJECT_REF:[email protected]:6543/postgres

# Session imzalama için en az 32 karakter rastgele string.
# Üretmek için (PowerShell):
#   "C:\Users\elif.cakir\Desktop\python-3.12.4\python.exe" -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace_with_at_least_32_random_chars

APP_ENV=development
